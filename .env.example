# Public base URL — no trailing slash
INVITO_BASE_URL=https://invito.example.com

# Path to SQLite database file
INVITO_DB_PATH=./invito.db

# 32-byte key for cookie signing and CalDAV password encryption.
# Generate with: openssl rand -hex 32
INVITO_SESSION_SECRET=replace-me-with-64-hex-characters-exactly

# OIDC provider (e.g. Authentik, Keycloak, Dex, Google)
INVITO_OIDC_ISSUER=https://auth.example.com/application/o/invito/
INVITO_OIDC_CLIENT_ID=your-client-id
INVITO_OIDC_CLIENT_SECRET=your-client-secret

# SMTP configuration
INVITO_SMTP_HOST=smtp.example.com
INVITO_SMTP_PORT=587
INVITO_SMTP_USER=invito@example.com
INVITO_SMTP_PASSWORD=your-smtp-password
INVITO_SMTP_FROM=invito@example.com

# HTTP listen address (default: :8080)
INVITO_LISTEN_ADDR=:8080

# CalDAV sync interval (default: 15m)
INVITO_SYNC_INTERVAL=15m

# How long PENDING bookings are held before auto-cancellation (default: 24h)
INVITO_BOOKING_TTL=24h
